{
  "name": "ask-database",
  "version": "0.1.0",
  "description": "Polski, schema-aware workspace do uczenia systemu struktury bazy i generowania bezpiecznego SQL.",
  "private": false,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter \"./packages/**\" build && pnpm --filter @ask-database/web dev",
    "dev:api": "pnpm --filter \"./packages/**\" build && pnpm --filter @ask-database/api dev",
    "build": "pnpm -r --sort build",
    "test": "pnpm -r --sort build && pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint:repo": "node scripts/check-public-hygiene.mjs"
  },
  "keywords": [
    "sql",
    "database",
    "natural-language-to-sql",
    "schema",
    "typescript",
    "polish"
  ],
  "author": "milekv",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
